		"name": "Facturacion API",
		"description": "API REST Facturacion (Spring Boot). Variable `baseUrl` por defecto http://localhost:8080. Tras crear cliente/producto/comprobante, copia los `id` de la respuesta a las variables `clienteId`, `productoId`, `comprobanteId`, `lineaId` para probar GET/PUT/DELETE.\n\nErrores de negocio y validacion: HTTP 409 con cuerpo `{ \"errores\": [ \"...\" ] }`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "clienteId", "value": "1" },
		{ "key": "productoId", "value": "1" },
		{ "key": "productoId2", "value": "2" },
		{ "key": "comprobanteId", "value": "1" },
		{ "key": "lineaId", "value": "1" }
	],
	"item": [
