						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"documento\": \"DOC-UNICO-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/api/clientes"
					}
				},
				{
					"name": "Actualizar cliente",
					"request": {
						"method": "PUT",
